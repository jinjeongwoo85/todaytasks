<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/subrow_body"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="0.2dp"
    android:paddingBottom="0.2dp"
    android:paddingStart="18dp">

    <ImageView
        android:id="@+id/subrow_check"
        android:layout_width="26dp"
        android:layout_height="26dp"
        android:padding="2dp"
        android:layout_marginEnd="9dp"
        android:src="@drawable/ic_check_circle_off"
        android:contentDescription="하위 완료 토글" />

    <TextView
        android:id="@+id/subrow_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#232323"
        android:textSize="17sp" />
</LinearLayout>
