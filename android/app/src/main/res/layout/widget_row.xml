<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="1dp"
    android:paddingBottom="1dp">

    <ImageView
        android:id="@+id/row_check"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:padding="3dp"
        android:layout_marginEnd="9dp"
        android:src="@drawable/ic_check_square_off"
        android:contentDescription="완료 토글" />

    <!-- 본문(제목 + 날짜/시간 라벨) — 탭하면 상세 열기. 라벨은 제목 오른쪽에 괄호로. -->
    <LinearLayout
        android:id="@+id/row_body"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/row_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:maxLines="1"
            android:ellipsize="end"
            android:textColor="#232323"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/row_meta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:visibility="gone"
            android:textColor="#6B6862"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- 우측: 카운트 + 펼침 토글 (하위 있는 행만 노출) -->
    <LinearLayout
        android:id="@+id/row_expand"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:paddingStart="10dp"
        android:paddingEnd="2dp">

        <TextView
            android:id="@+id/row_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minWidth="26dp"
            android:gravity="end"
            android:textColor="#A8A29A"
            android:textSize="12sp"
            android:fontFamily="monospace" />

        <ImageView
            android:id="@+id/row_toggle"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:layout_marginStart="2dp"
            android:src="@drawable/ic_chevron_right"
            android:contentDescription="하위 할 일 펼치기" />
    </LinearLayout>
</LinearLayout>
